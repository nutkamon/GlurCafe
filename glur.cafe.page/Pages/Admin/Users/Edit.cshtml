@page "{id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "แก้ไขผู้ดูแลระบบ";
    ViewData["ActiveMenu"] = "users";
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-pencil-square me-2"></i>แก้ไขผู้ดูแลระบบ</span>
        <a href="/Admin/Users" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>กลับ
        </a>
    </div>
    <div class="p-4">
        <form method="post">
            <input type="hidden" asp-for="AdminUser.Id" />
            <input type="hidden" asp-for="AdminUser.CreatedAt" />
            <input type="hidden" asp-for="AdminUser.PasswordHash" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0"><i class="bi bi-person me-1"></i>ข้อมูลผู้ดูแล</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="AdminUser.Username" class="form-label fw-semibold">ชื่อผู้ใช้ <span class="text-danger">*</span></label>
                            <input asp-for="AdminUser.Username" class="form-control" />
                            <span asp-validation-for="AdminUser.Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AdminUser.DisplayName" class="form-label fw-semibold">ชื่อที่แสดง</label>
                            <input asp-for="AdminUser.DisplayName" class="form-control" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="AdminUser.IsActive" class="form-check-input" />
                                <label asp-for="AdminUser.IsActive" class="form-check-label">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h6 class="mb-0"><i class="bi bi-key me-1"></i>เปลี่ยนรหัสผ่าน</h6></div>
                <div class="card-body">
                    <div class="alert alert-info small py-2">
                        <i class="bi bi-info-circle me-1"></i>เว้นว่างไว้หากไม่ต้องการเปลี่ยนรหัสผ่าน
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label fw-semibold">รหัสผ่านใหม่</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="อย่างน้อย 6 ตัวอักษร" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">ยืนยันรหัสผ่านใหม่</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="กรอกรหัสผ่านอีกครั้ง" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-end">
                <a href="/Admin/Users" class="btn btn-outline-secondary me-2">ยกเลิก</a>
                <button type="submit" class="btn btn-teal">
                    <i class="bi bi-check-circle me-1"></i>บันทึกการแก้ไข
                </button>
            </div>
        </form>
    </div>
</div>
