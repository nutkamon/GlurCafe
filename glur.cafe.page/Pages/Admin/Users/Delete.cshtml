@page "{id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "ลบผู้ดูแลระบบ";
    ViewData["ActiveMenu"] = "users";
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-trash me-2 text-danger"></i>ยืนยันการลบผู้ดูแลระบบ</span>
        <a href="/Admin/Users" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>กลับ
        </a>
    </div>
    <div class="p-4">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            คุณต้องการลบผู้ดูแล <strong>@Model.AdminUser.Username</strong> (@Model.AdminUser.DisplayName) หรือไม่?
            <br /><small>การลบนี้ไม่สามารถย้อนกลับได้</small>
        </div>
        <form method="post">
            <div class="d-flex gap-2">
                <a href="/Admin/Users" class="btn btn-outline-secondary">ยกเลิก</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>ยืนยันลบ
                </button>
            </div>
        </form>
    </div>
</div>
