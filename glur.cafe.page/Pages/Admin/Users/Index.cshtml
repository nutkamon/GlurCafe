@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "ผู้ดูแลระบบ";
    ViewData["ActiveMenu"] = "users";
    ViewData["UnreadCount"] = Model.Users.Count;
}

<div class="admin-card">
    @Html.AntiForgeryToken()
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people me-2"></i>ผู้ดูแลระบบทั้งหมด (@Model.Users.Count)</span>
        <a href="/Admin/Users/Create" class="btn btn-sm btn-teal">
            <i class="bi bi-plus-lg me-1"></i>เพิ่มผู้ดูแล
        </a>
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Bulk Action Bar -->
    <div id="bulkActionBar" class="d-none px-3 py-2 border-bottom bg-light d-flex align-items-center gap-3">
        <span id="selectedCount" class="small fw-semibold text-muted"></span>
        <form id="bulkDeleteForm" method="post" asp-page-handler="BulkDelete" class="d-inline" onsubmit="return confirm('ลบผู้ดูแลที่เลือกทั้งหมด?')">
            @Html.AntiForgeryToken()
            <div id="bulkIdsContainer"></div>
            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash me-1"></i>ลบที่เลือก</button>
        </form>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="cancelBulk">ยกเลิก</button>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-header">
                <tr>
                    <th style="width:40px"><input type="checkbox" id="selectAll" class="form-check-input"></th>
                    <th style="width:50px">#</th>
                    <th>ชื่อผู้ใช้</th>
                    <th class="d-none d-md-table-cell">ชื่อที่แสดง</th>
                    <th style="width:100px">สถานะ</th>
                    <th class="d-none d-md-table-cell">สร้างเมื่อ</th>
                    <th class="d-none d-lg-table-cell">เข้าสู่ระบบล่าสุด</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input row-check" data-id="@user.Id"></td>
                        <td class="text-muted small">@user.Id</td>
                        <td class="fw-semibold">@user.Username</td>
                        <td class="d-none d-md-table-cell text-muted small">@user.DisplayName</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-teal rounded-pill" style="font-size:.7rem">เปิดใช้งาน</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill" style="font-size:.7rem">ปิดใช้งาน</span>
                            }
                        </td>
                        <td class="d-none d-md-table-cell text-muted small">@user.CreatedAt.ToString("dd/MM/yy HH:mm")</td>
                        <td class="d-none d-lg-table-cell text-muted small">@(user.LastLoginAt?.ToString("dd/MM/yy HH:mm") ?? "-")</td>
                        <td class="text-end">
                            <a href="/Admin/Users/Edit/@user.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@user.Id, '@user.Username')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">ยังไม่มีผู้ดูแลระบบ</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <nav class="px-3 pt-2 pb-1">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNum ? "active" : "")">
                        <a class="page-link" href="?Page=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id, name) {
        Swal.fire({
            title: 'ยืนยันการลบ',
            html: 'คุณต้องการลบผู้ดูแล <strong>' + name + '</strong> หรือไม่?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'ลบเลย',
            cancelButtonText: 'ยกเลิก'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/Admin/Users/Delete/' + id, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                    }
                }).then(() => window.location.reload());
            }
        });
    }
</script>
