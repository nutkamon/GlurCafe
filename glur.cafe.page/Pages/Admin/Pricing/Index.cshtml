@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Pricing.IndexModel
@{
    ViewData["Title"] = "ราคา & แพ็คเกจ";
    ViewData["ActiveMenu"] = "pricing";
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-tags me-2"></i>แพ็คเกจทั้งหมด (@Model.Plans.Count)</span>
        <a href="/Admin/Pricing/Create" class="btn btn-sm btn-teal">
            <i class="bi bi-plus-lg me-1"></i>เพิ่มแพ็คเกจ
        </a>
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Bulk Action Bar -->
    <div id="bulkActionBar" class="d-none px-3 py-2 border-bottom bg-light d-flex align-items-center gap-3">
        <span id="selectedCount" class="small fw-semibold text-muted"></span>
        <form id="bulkDeleteForm" method="post" asp-page-handler="BulkDelete" class="d-inline" onsubmit="return confirm('ลบรายการที่เลือกทั้งหมด?')">
            @Html.AntiForgeryToken()
            <div id="bulkIdsContainer"></div>
            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash me-1"></i>ลบที่เลือก</button>
        </form>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="cancelBulk">ยกเลิก</button>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-header">
                <tr>
                    <th style="width:40px"><input type="checkbox" id="selectAll" class="form-check-input"></th>
                    <th style="width:50px">#</th>
                    <th>ชื่อแพ็คเกจ</th>
                    <th>ราคา</th>
                    <th class="d-none d-md-table-cell">CTA</th>
                    <th style="width:80px">ยอดนิยม</th>
                    <th style="width:80px">ลำดับ</th>
                    <th style="width:80px">สถานะ</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Plans)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input row-check" data-id="@p.Id"></td>
                        <td class="text-muted small">@p.Id</td>
                        <td class="fw-semibold">@p.Name</td>
                        <td><span class="fw-bold text-teal">@p.Price</span> <small class="text-muted">@p.PriceUnit</small></td>
                        <td class="d-none d-md-table-cell small">@p.CtaText</td>
                        <td class="text-center">
                            @if (p.IsPopular) { <span class="badge bg-warning text-dark">ยอดนิยม</span> }
                        </td>
                        <td class="text-center">@p.DisplayOrder</td>
                        <td>
                            <form method="post" asp-page-handler="Toggle">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-success" : "btn-secondary") rounded-pill" style="font-size:0.7rem">
                                    @(p.IsActive ? "เปิด" : "ปิด")
                                </button>
                            </form>
                        </td>
                        <td class="text-end">
                            <a href="/Admin/Pricing/Edit/@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('ลบแพ็คเกจนี้?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <nav class="px-3 pt-2 pb-1">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNum ? "active" : "")">
                        <a class="page-link" href="?PageNum=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
