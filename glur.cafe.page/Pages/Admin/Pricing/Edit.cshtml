@page "{id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Pricing.EditModel
@{
    ViewData["Title"] = "แก้ไขแพ็คเกจ";
    ViewData["ActiveMenu"] = "pricing";
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-pencil me-2"></i>แก้ไขแพ็คเกจ</span>
        <a href="/Admin/Pricing" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>กลับ
        </a>
    </div>
    <div class="p-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Plan.Id" />
            <input type="hidden" asp-for="Plan.CreatedAt" />
            <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Plan.Name" class="form-label fw-semibold"></label>
                    <input asp-for="Plan.Name" class="form-control" />
                    <span asp-validation-for="Plan.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Plan.Price" class="form-label fw-semibold"></label>
                    <input asp-for="Plan.Price" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Plan.PriceUnit" class="form-label fw-semibold"></label>
                    <input asp-for="Plan.PriceUnit" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Plan.Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Plan.Description" class="form-control ck-editor-target" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label for="FeaturesText" class="form-label fw-semibold">คุณสมบัติ (1 บรรทัด = 1 รายการ)</label>
                    <textarea id="FeaturesText" name="FeaturesText" class="form-control ck-editor-target" rows="5">@Model.FeaturesText</textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Plan.CtaText" class="form-label fw-semibold"></label>
                    <input asp-for="Plan.CtaText" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Plan.DisplayOrder" class="form-label fw-semibold"></label>
                    <input asp-for="Plan.DisplayOrder" class="form-control" type="number" min="1" />
                </div>
                <div class="col-md-3 d-flex flex-column justify-content-end gap-2">
                    <div class="form-check form-switch">
                        <input asp-for="Plan.IsPopular" class="form-check-input" type="checkbox" />
                        <label asp-for="Plan.IsPopular" class="form-check-label">ยอดนิยม</label>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="Plan.IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="Plan.IsActive" class="form-check-label">เปิดใช้งาน</label>
                    </div>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <a href="/Admin/Pricing" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-teal px-4">
                        <i class="bi bi-floppy me-1"></i>บันทึก
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
