@page
@model glur.cafe.page.Pages.Admin.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "เข้าสู่ระบบ";
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>เข้าสู่ระบบ — GLUR CAFE Admin</title>
    <link rel="icon" type="image/png" href="/img/Logo-removebg-preview.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root { --teal: #00A59A; --teal-dark: #007A72; }
        * { font-family: 'Noto Sans Thai', sans-serif; }
        body { background: linear-gradient(135deg, #003D3A 0%, #005550 40%, #4A7C5F 80%, #6B4423 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: rgba(255,255,255,0.97); border-radius: 20px; padding: 2.5rem; max-width: 420px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
        .login-logo { text-align: center; margin-bottom: 1.5rem; }
        .login-logo .icon { width: 70px; height: 70px; background: linear-gradient(135deg, var(--teal), var(--teal-dark)); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2rem; color: white; margin-bottom: 0.75rem; }
        .login-logo h4 { color: #1a1a1a; font-weight: 700; margin: 0; font-size: 1.3rem; }
        .login-logo p { color: #666; font-size: 0.85rem; margin: 0; }
        .form-control { border-radius: 10px; padding: 0.65rem 1rem; border: 1.5px solid #e0e0e0; }
        .form-control:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(0,165,154,0.15); }
        .btn-login { background: linear-gradient(135deg, var(--teal), var(--teal-dark)); color: white; border: none; border-radius: 12px; padding: 0.75rem; font-weight: 600; font-size: 1rem; width: 100%; }
        .btn-login:hover { opacity: 0.9; color: white; }
        .input-icon { position: relative; }
        .input-icon .bi { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #888; }
        .input-icon input { padding-left: 2.4rem; }
        .error-msg { color: #dc3545; font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <img src="/img/Logo-removebg-preview.png" alt="GLUR CAFE" style="width:80px;height:auto;margin-bottom:0.75rem;" />
            <h4>GLUR CAFE</h4>
            <p>ระบบจัดการเนื้อหา</p>
        </div>
        <form method="post">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage
                </div>
            }
            <div class="mb-3">
                <label class="form-label fw-semibold small">ชื่อผู้ใช้</label>
                <div class="input-icon">
                    <i class="bi bi-person"></i>
                    <input type="text" name="Username" class="form-control" placeholder="กรอกชื่อผู้ใช้" required autocomplete="username"/>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold small">รหัสผ่าน</label>
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="Password" class="form-control" placeholder="กรอกรหัสผ่าน" required autocomplete="current-password"/>
                </div>
            </div>
            <button type="submit" class="btn btn-login">
                <i class="bi bi-box-arrow-in-right me-2"></i>เข้าสู่ระบบ
            </button>
        </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
