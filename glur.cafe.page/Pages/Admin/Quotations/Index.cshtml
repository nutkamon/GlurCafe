@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Quotations.IndexModel
@{
    ViewData["Title"] = "ใบเสนอราคา";
    ViewData["ActiveMenu"] = "quotations";
    string active = Model.StatusFilter ?? "";
    string search = Model.Search ?? "";
}

<!-- Revenue Summary -->
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="admin-card p-3 text-center">
            <div class="text-muted small mb-1"><i class="bi bi-cash-stack me-1"></i>รายได้รวมทั้งหมด</div>
            <div class="fw-bold fs-5 text-teal">@Model.TotalRevenue.ToString("#,##0") ฿</div>
            <div class="text-muted" style="font-size:.75rem">@Model.QuotationsPaidCount ใบ</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card p-3 text-center">
            <div class="text-muted small mb-1"><i class="bi bi-calendar-check me-1"></i>รายได้เดือนนี้</div>
            <div class="fw-bold fs-5 text-teal">@Model.RevenueThisMonth.ToString("#,##0") ฿</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card p-3 text-center">
            <div class="text-muted small mb-1"><i class="bi bi-calendar-minus me-1"></i>รายได้เดือนที่แล้ว</div>
            <div class="fw-bold fs-5">@Model.RevenueLastMonth.ToString("#,##0") ฿</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="admin-card p-3 text-center">
            <div class="text-muted small mb-1"><i class="bi bi-hourglass-split me-1"></i>ยอดรอรับชำระ</div>
            <div class="fw-bold fs-5 text-warning">@Model.PendingPaymentAmount.ToString("#,##0") ฿</div>
            <div class="text-muted" style="font-size:.75rem">@Model.QuotationsAcceptedCount ใบ</div>
        </div>
    </div>
</div>

<div class="admin-card mb-3">
    <!-- Filter Tabs -->
    <div class="admin-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex flex-wrap gap-1">
            <a href="?StatusFilter=&Search=@search" class="btn btn-sm @(active == "" ? "btn-teal" : "btn-outline-teal")">
                ทั้งหมด <span class="badge @(active == "" ? "bg-white text-teal" : "bg-teal") ms-1">@Model.CountAll</span>
            </a>
            <a href="?StatusFilter=draft&Search=@search" class="btn btn-sm @(active == "draft" ? "btn-teal" : "btn-outline-teal")">
                ร่าง <span class="badge @(active == "draft" ? "bg-white text-teal" : "bg-secondary") ms-1">@Model.CountDraft</span>
            </a>
            <a href="?StatusFilter=sent&Search=@search" class="btn btn-sm @(active == "sent" ? "btn-teal" : "btn-outline-teal")">
                ส่งแล้ว <span class="badge @(active == "sent" ? "bg-white text-teal" : "bg-secondary") ms-1">@Model.CountSent</span>
            </a>
            <a href="?StatusFilter=accepted&Search=@search" class="btn btn-sm @(active == "accepted" ? "btn-teal" : "btn-outline-teal")">
                ตอบรับ <span class="badge @(active == "accepted" ? "bg-white text-teal" : "bg-secondary") ms-1">@Model.CountAccepted</span>
            </a>
            <a href="?StatusFilter=paid&Search=@search" class="btn btn-sm @(active == "paid" ? "btn-teal" : "btn-outline-teal")">
                ชำระแล้ว <span class="badge @(active == "paid" ? "bg-white text-teal" : "bg-secondary") ms-1">@Model.CountPaid</span>
            </a>
            <a href="?StatusFilter=completed&Search=@search" class="btn btn-sm @(active == "completed" ? "btn-teal" : "btn-outline-teal")">
                เสร็จสิ้น <span class="badge @(active == "completed" ? "bg-white text-teal" : "bg-secondary") ms-1">@Model.CountCompleted</span>
            </a>
        </div>
        <div class="d-flex gap-2">
            <form method="get" class="d-flex gap-2">
                <input type="hidden" name="StatusFilter" value="@active" />
                <input type="search" name="Search" value="@search" class="form-control form-control-sm" placeholder="ค้นหาเลขที่/ลูกค้า" style="width:200px" />
                <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
            </form>
            <a href="/Admin/Quotations/Create" class="btn btn-sm btn-teal">
                <i class="bi bi-plus-lg me-1"></i>สร้างใหม่
            </a>
        </div>
    </div>

    <!-- Table -->
    <!-- Bulk Action Bar -->
    <div id="bulkActionBar" class="d-none px-3 py-2 border-bottom bg-light d-flex align-items-center gap-3">
        <span id="selectedCount" class="small fw-semibold text-muted"></span>
        <form id="bulkDeleteForm" method="post" asp-page-handler="BulkDelete" class="d-inline" onsubmit="return confirm('ลบใบเสนอราคาที่เลือกทั้งหมด?')">
            @Html.AntiForgeryToken()
            <div id="bulkIdsContainer"></div>
            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash me-1"></i>ลบที่เลือก</button>
        </form>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="cancelBulk">ยกเลิก</button>
    </div>
    @if (Model.Quotations.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-header">
                    <tr>
                        <th style="width:40px"><input type="checkbox" id="selectAll" class="form-check-input"></th>
                        <th>เลขที่</th>
                        <th>ลูกค้า</th>
                        <th>เบอร์โทร</th>
                        <th class="text-end">ยอดสุทธิ</th>
                        <th>สถานะ</th>
                        <th>การชำระ</th>
                        <th>วันที่</th>
                        <th class="text-center">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model.Quotations)
                    {
                        <tr>
                            <td><input type="checkbox" class="form-check-input row-check" data-id="@q.Id"></td>
                            <td><a href="/Admin/Quotations/Detail/@q.Id" class="fw-semibold text-decoration-none">@q.QuotationNumber</a></td>
                            <td>@q.CustomerName</td>
                            <td><small class="text-muted">@(q.Phone ?? "-")</small></td>
                            <td class="text-end fw-semibold">@q.NetAmount.ToString("#,##0") ฿</td>
                            <td><span class="badge @GetStatusBadge(q.Status)">@GetStatusLabel(q.Status)</span></td>
                            <td><span class="badge @GetPaymentBadge(q.PaymentStatus)">@GetPaymentLabel(q.PaymentStatus)</span></td>
                            <td><small class="text-muted">@q.CreatedAt.ToString("dd/MM/yy")</small></td>
                            <td class="text-center">
                                <a href="/Admin/Quotations/Detail/@q.Id" class="btn btn-sm btn-outline-secondary me-1" title="ดูรายละเอียด"><i class="bi bi-eye"></i></a>
                                <a href="/Admin/Quotations/Edit/@q.Id" class="btn btn-sm btn-outline-secondary me-1" title="แก้ไข"><i class="bi bi-pencil"></i></a>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-quote"
                                        data-id="@q.Id" data-number="@q.QuotationNumber" title="ลบ">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-receipt fs-1 d-block mb-2"></i>
            ไม่พบใบเสนอราคา
        </div>
    }
    @if (Model.TotalPages > 1)
    {
        <nav class="px-3 pt-2 pb-1">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNum ? "active" : "")">
                        <a class="page-link" href="?StatusFilter=@active&Search=@search&PageNum=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@functions {
    string GetStatusLabel(string s) => s switch {
        "draft" => "ร่าง", "sent" => "ส่งแล้ว", "accepted" => "ตอบรับ",
        "rejected" => "ปฏิเสธ", "paid" => "ชำระแล้ว", "completed" => "เสร็จสิ้น",
        "cancelled" => "ยกเลิก", _ => s };
    string GetStatusBadge(string s) => s switch {
        "draft" => "bg-secondary", "sent" => "bg-info text-dark", "accepted" => "bg-success",
        "rejected" => "bg-danger", "paid" => "bg-success", "completed" => "bg-success",
        "cancelled" => "bg-secondary", _ => "bg-secondary" };
    string GetPaymentLabel(string s) => s switch {
        "unpaid" => "ยังไม่ชำระ", "partial" => "ชำระบางส่วน", "paid" => "ชำระครบ", _ => s };
    string GetPaymentBadge(string s) => s switch {
        "unpaid" => "bg-secondary", "partial" => "bg-warning text-dark", "paid" => "bg-teal", _ => "bg-secondary" };
}

@section Scripts {
<script>
document.querySelectorAll('.btn-delete-quote').forEach(btn => {
    btn.addEventListener('click', function () {
        const id = this.dataset.id;
        const num = this.dataset.number;
        Swal.fire({
            title: 'ยืนยันการลบ',
            text: `ลบใบเสนอราคา ${num} หรือไม่?`,
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#d33', cancelButtonColor: '#6c757d',
            confirmButtonText: 'ลบ', cancelButtonText: 'ยกเลิก'
        }).then(result => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'post'; form.action = '/Admin/Quotations?handler=Delete';
                const token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) form.append(token.cloneNode());
                const input = document.createElement('input');
                input.type = 'hidden'; input.name = 'id'; input.value = id;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        });
    });
});
</script>
}
