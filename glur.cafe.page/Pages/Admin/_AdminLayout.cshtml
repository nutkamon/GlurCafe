<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GLUR CAFE Admin</title>
    <link rel="icon" type="image/png" href="/img/Logo-removebg-preview.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/admin.css" asp-append-version="true" />
</head>
<body>
<!-- Sidebar -->
<div class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
        <img src="/img/Logo-removebg-preview.png" alt="GLUR CAFE" style="height:36px;width:auto;" />
        <span>GLUR CAFE</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">จัดการเนื้อหา</div>
        <a href="/Admin" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i><span>แดชบอร์ด</span>
        </a>
        <a href="/Admin/Services" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "services" ? "active" : "")">
            <i class="bi bi-grid-3x3-gap"></i><span>บริการ</span>
        </a>
        <a href="/Admin/Portfolios" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "portfolios" ? "active" : "")">
            <i class="bi bi-images"></i><span>แกลเลอรี่</span>
        </a>
        <a href="/Admin/Pricing" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "pricing" ? "active" : "")">
            <i class="bi bi-tags"></i><span>ราคา & แพ็คเกจ</span>
        </a>
        <div class="nav-section-label mt-3">ข้อมูล</div>
        <a href="/Admin/Messages" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "messages" ? "active" : "")">
            <i class="bi bi-envelope"></i><span>ข้อความ</span>
            @{
                var unread = ViewData["UnreadCount"];
                if (unread != null && (int)unread > 0)
                {
                    <span class="badge-count">@unread</span>
                }
            }
        </a>
        <a href="/Admin/Settings" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "settings" ? "active" : "")">
            <i class="bi bi-gear"></i><span>ตั้งค่า</span>
        </a>
        <div class="nav-section-label mt-3">เพิ่มเติม</div>
        <a href="/Admin/Customers" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "customers" ? "active" : "")">
            <i class="bi bi-people"></i><span>CRM ลูกค้า</span>
        </a>
        <a href="/Admin/Quotations" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "quotations" ? "active" : "")">
            <i class="bi bi-receipt"></i><span>ใบเสนอราคา</span>
        </a>
        <a href="/Admin/Analytics" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "analytics" ? "active" : "")">
            <i class="bi bi-graph-up"></i><span>รายงาน</span>
        </a>
        <a href="/Admin/Users" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "users" ? "active" : "")">
            <i class="bi bi-people"></i><span>ผู้ดูแลระบบ</span>
        </a>
        <div class="nav-section-label mt-3">ต้นทุนสินค้า</div>
        <a href="/Admin/Beans" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "beans" ? "active" : "")">
            <i class="bi bi-bag"></i><span>สารกาแฟ (Master)</span>
        </a>
        <a href="/Admin/CostCalc" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "costcalc" ? "active" : "")">
            <i class="bi bi-calculator"></i><span>คำนวณต้นทุน</span>
        </a>
        <div class="nav-section-label mt-3">การเงิน</div>
        <a href="/Admin/Finance" class="sidebar-link @(ViewData["ActiveMenu"]?.ToString() == "finance" ? "active" : "")">
            <i class="bi bi-cash-coin"></i><span>รายรับ - รายจ่าย</span>
        </a>
    </nav>
    <div class="sidebar-footer">
        <a href="/" target="_blank" class="sidebar-link">
            <i class="bi bi-box-arrow-up-right"></i><span>ดูเว็บไซต์</span>
        </a>
        <a href="/Admin/Logout" class="sidebar-link text-danger">
            <i class="bi bi-box-arrow-right"></i><span>ออกจากระบบ</span>
        </a>
    </div>
</div>

<!-- Main content -->
<div class="admin-main" id="adminMain">
    <!-- Top bar -->
    <div class="admin-topbar">
        <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>
        <div class="topbar-title">@ViewData["Title"]</div>
        <div class="topbar-user">
            <i class="bi bi-person-circle me-2"></i>
            <span>@User.Identity?.Name</span>
        </div>
    </div>

    <!-- Page content -->
    <div class="admin-content">
        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>
<script src="/js/admin.js" asp-append-version="true"></script>
@{
    var _successMsg = TempData["Success"] as string;
    var _errorMsg   = TempData["Error"]   as string;
}
@if (!string.IsNullOrEmpty(_successMsg) || !string.IsNullOrEmpty(_errorMsg))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            @if (!string.IsNullOrEmpty(_successMsg))
            {
                <text>
                Swal.fire({ icon: 'success', title: 'สำเร็จ', text: @Json.Serialize(_successMsg),
                    timer: 2500, showConfirmButton: false, toast: true, position: 'top-end' });
                </text>
            }
            @if (!string.IsNullOrEmpty(_errorMsg))
            {
                <text>
                Swal.fire({ icon: 'error', title: 'เกิดข้อผิดพลาด', text: @Json.Serialize(_errorMsg) });
                </text>
            }
        });
    </script>
}
@await RenderSectionAsync("Scripts", required: false)

<!-- Upload progress overlay -->
<div id="uploadOverlay" style="display:none; position:fixed; inset:0; z-index:9999;
     background:rgba(0,0,0,0.65); flex-direction:column;
     align-items:center; justify-content:center; gap:1.25rem;">
    <div class="spinner-border text-light" style="width:3rem;height:3rem;" role="status"></div>
    <p id="uploadOverlayText" style="color:#fff; font-size:1.05rem; margin:0; font-weight:500;">
        กำลังอัปโหลด...
    </p>
    <p style="color:rgba(255,255,255,0.6); font-size:0.82rem; margin:0;">กรุณารอสักครู่ อย่าปิดหน้าต่างนี้</p>
</div>
</body>
</html>
