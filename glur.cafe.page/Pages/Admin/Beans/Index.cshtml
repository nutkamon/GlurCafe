@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Beans.IndexModel
@{
    ViewData["Title"] = "ข้อมูลสารกาแฟ";
    ViewData["ActiveMenu"] = "beans";
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-bag me-2"></i>สารกาแฟทั้งหมด (@Model.Beans.Count)</span>
        <a href="/Admin/Beans/Create" class="btn btn-sm btn-teal">
            <i class="bi bi-plus-lg me-1"></i>เพิ่มสารกาแฟ
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-header">
                <tr>
                    <th style="width:50px">#</th>
                    <th>ชื่อสาร</th>
                    <th class="text-end" style="width:160px">ราคา/กก. (฿)</th>
                    <th class="d-none d-md-table-cell">หมายเหตุ</th>
                    <th style="width:90px" class="text-center">สถานะ</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.Beans)
                {
                    <tr>
                        <td class="text-muted small">@b.Id</td>
                        <td class="fw-semibold">@b.Name</td>
                        <td class="text-end fw-bold text-success">@b.PricePerKg.ToString("#,##0.00")</td>
                        <td class="d-none d-md-table-cell text-muted small">@b.Notes</td>
                        <td class="text-center">
                            <form method="post" asp-page-handler="Toggle">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm @(b.IsActive ? "btn-success" : "btn-secondary") rounded-pill" style="font-size:.7rem">
                                    @(b.IsActive ? "เปิด" : "ปิด")
                                </button>
                            </form>
                        </td>
                        <td class="text-end">
                            <a href="/Admin/Beans/Edit/@b.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  onsubmit='return confirm("ลบสาร @b.Name นี้?")' >
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Beans.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">ยังไม่มีข้อมูลสารกาแฟ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
