@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.Services.IndexModel
@{
    ViewData["Title"] = "จัดการบริการ";
    ViewData["ActiveMenu"] = "services";
    ViewData["UnreadCount"] = Model.Services.Count;
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-grid-3x3-gap me-2"></i>บริการทั้งหมด (@Model.Services.Count)</span>
        <a href="/Admin/Services/Create" class="btn btn-sm btn-teal">
            <i class="bi bi-plus-lg me-1"></i>เพิ่มบริการ
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-header">
                <tr>
                    <th style="width:50px">#</th>
                    <th>ชื่อบริการ</th>
                    <th class="d-none d-md-table-cell">คำอธิบาย</th>
                    <th style="width:80px">Icon</th>
                    <th style="width:80px">ลำดับ</th>
                    <th style="width:80px">สถานะ</th>
                    <th style="width:120px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Services)
                {
                    <tr>
                        <td><input type="checkbox" class="form-check-input row-check" data-id="@s.Id"></td>
                        <td class="text-muted small">@s.Id</td>
                        <td class="fw-semibold">@s.Title</td>
                        @{ var plainDesc = System.Text.RegularExpressions.Regex.Replace(s.Description ?? "", "<.*?>", ""); }
                        <td class="d-none d-md-table-cell small text-muted">@(plainDesc.Length > 80 ? plainDesc[..80] + "…" : plainDesc)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(s.ImagePath))
                            {
                                <img src="@s.ImagePath" alt="@s.Title" style="height:36px;width:36px;object-fit:cover;border-radius:6px;" />
                            }
                            else
                            {
                                <i class="bi @s.IconClassName fs-5"></i>
                            }
                        </td>
                        <td class="text-center">@s.DisplayOrder</td>
                        <td>
                            <form method="post" asp-page-handler="Toggle">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn btn-sm @(s.IsActive ? "btn-success" : "btn-secondary") rounded-pill" style="font-size:0.7rem">
                                    @(s.IsActive ? "เปิด" : "ปิด")
                                </button>
                            </form>
                        </td>
                        <td class="text-end">
                            <a href="/Admin/Services/Edit/@s.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('ลบบริการนี้?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <nav class="px-3 pt-2 pb-1">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNum ? "active" : "")">
                        <a class="page-link" href="?PageNum=@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
