@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@model glur.cafe.page.Pages.Admin.CostCalc.IndexModel
@{
    ViewData["Title"] = "คำนวณต้นทุนสินค้า";
    ViewData["ActiveMenu"] = "costcalc";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1 fw-bold"><i class="bi bi-calculator me-2 text-teal"></i>คำนวณต้นทุนสินค้า</h5>
        <small class="text-muted">บันทึกสูตรการคำนวณต้นทุนเมล็ดกาแฟต่อ 1 กิโลกรัม</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/Admin/Beans" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-bag me-1"></i>จัดการสารกาแฟ
        </a>
        <a href="/Admin/CostCalc/Print" target="_blank" class="btn btn-outline-teal btn-sm">
            <i class="bi bi-printer me-1"></i>Print / PDF
        </a>
        <a href="/Admin/CostCalc/Create" class="btn btn-teal btn-sm">
            <i class="bi bi-plus-lg me-1"></i>คำนวณใหม่
        </a>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <i class="bi bi-list-ul me-2"></i>สูตรที่บันทึกไว้ (@Model.Products.Count รายการ)
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-header">
                <tr>
                    <th>#</th>
                    <th>ชื่อสินค้า</th>
                    <th class="d-none d-md-table-cell">ส่วนผสม</th>
                    <th class="text-center d-none d-md-table-cell" style="width:110px">สูญหาย (%)</th>
                    <th class="text-center d-none d-md-table-cell" style="width:120px">ค่าดำเนินการ</th>
                    <th class="text-end" style="width:150px">ต้นทุน/กก. (฿)</th>
                    <th class="text-end d-none d-lg-table-cell" style="width:150px">ราคาขาย (฿)</th>
                    <th class="text-end d-none d-lg-table-cell" style="width:100px">กำไร (%)</th>
                    <th style="width:110px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Products)
                {
                    <tr>
                        <td class="text-muted small">@p.Id</td>
                        <td class="fw-semibold">@p.ProductName</td>
                        <td class="d-none d-md-table-cell small text-muted">
                            @string.Join(", ", p.Items.Select(i => $"{i.BeanName} ({i.RatioPercent:0}%)"))
                        </td>
                        <td class="text-center d-none d-md-table-cell">@p.LossRate.ToString("0.#")%</td>
                        <td class="text-center d-none d-md-table-cell">@p.ProcessingFee.ToString("#,##0") ฿</td>
                        <td class="text-end fw-bold text-success fs-6">@p.CostPerKg.ToString("#,##0.00") ฿</td>
                        <td class="text-end d-none d-lg-table-cell fw-semibold">
                            @(p.SellingPrice > 0 ? p.SellingPrice.ToString("#,##0.00") + " ฿" : "-")
                        </td>
                        <td class="text-end d-none d-lg-table-cell fw-bold @(p.ProfitPercent >= 0 ? "text-success" : "text-danger")">
                            @(p.SellingPrice > 0 ? p.ProfitPercent.ToString("0.##") + "%" : "-")
                        </td>
                        <td class="text-end">
                            <a href="/Admin/CostCalc/Edit/@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" class="d-inline"
                                  onsubmit='return confirm("ลบรายการ @p.ProductName?")' >
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Products.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-5">
                            <i class="bi bi-calculator fs-2 d-block mb-2 opacity-25"></i>
                            ยังไม่มีสูตรที่บันทึกไว้
                            <div class="mt-2">
                                <a href="/Admin/CostCalc/Create" class="btn btn-sm btn-teal">
                                    <i class="bi bi-plus-lg me-1"></i>คำนวณสูตรแรก
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
